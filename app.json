{
  "expo": {
    "name": "Pip Calculator Forex",
    "slug": "pip-calculator-forex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pipcalculator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.faxacademy.pipcalculator",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#203b51"
      },
      "package": "com.faxacademy.pipcalculator",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f4d01e08-44d0-4a19-a68d-3a6658f55fe8"
      }
    },
    "description": "A professional forex pip calculator for traders to calculate profit, loss, and position sizes.",
    "primaryColor": "#203b51",
    "privacy": "public",
    "githubUrl": "https://github.com/faxacademy/pip-calculator-forex",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/f4d01e08-44d0-4a19-a68d-3a6658f55fe8"
    }
  }
}